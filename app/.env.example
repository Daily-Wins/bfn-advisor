# OpenRouter API key for LLM calls and embeddings
# Get from https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Turso (libSQL) database
# Get from https://turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=...

# Auth0 OAuth application
# Get from https://manage.auth0.com
AUTH_AUTH0_ID=...
AUTH_AUTH0_SECRET=...
AUTH_AUTH0_ISSUER=https://your-tenant.auth0.com

# 32+ char random string for Auth.js session encryption
# Generate: openssl rand -hex 32
AUTH_SECRET=...
